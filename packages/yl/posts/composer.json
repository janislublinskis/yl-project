{
    "name": "yl/posts",
    "description": "YL Posts module — Post CRUD API with async RabbitMQ publish job",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.50",
        "yl/helper": "*",
        "vladimir-yuldashev/laravel-queue-rabbitmq": "^14.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "fakerphp/faker": "^1.23",
        "orchestra/testbench": "^9.0",
        "phparkitect/phparkitect": "^0.8"
    },
    "autoload": {
        "psr-4": {
            "Yl\\Posts\\": "src/",
            "Yl\\Posts\\Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yl\\Posts\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yl\\Posts\\PostsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
